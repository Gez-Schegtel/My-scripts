#!/bin/bash

# Nombre del paquete
PACKAGE="discord"

# URL de descarga
DOWNLOAD_URL="https://discord.com/api/download?platform=linux"

# Nombre del archivo temporal
DEB_FILE="/tmp/discord.deb"

# Verificar si wget está instalado
if ! command -v wget &>/dev/null; then
	echo "❌ Error: wget no está instalado. Instálalo con:"
	echo "   sudo apt install wget"
	exit 1
fi

# Obtener la versión instalada (si existe)
INSTALLED_VERSION=$(dpkg-query -W -f='${Version}' $PACKAGE 2>/dev/null)

# Descargar el archivo .deb temporalmente
echo "🔄 Descargando la última versión de Discord..."
wget -O "$DEB_FILE" "$DOWNLOAD_URL" &>/dev/null

# Verificar si la descarga fue exitosa
if [[ $? -ne 0 ]]; then
	echo "❌ Error: Falló la descarga del paquete."
	exit 1
fi

# Obtener la versión del nuevo paquete
NEW_VERSION=$(dpkg-deb --info "$DEB_FILE" | grep 'Version:' | awk '{print $2}')

# Comparar versiones
if [[ -n "$INSTALLED_VERSION" && "$INSTALLED_VERSION" == "$NEW_VERSION" ]]; then
	echo "✅ Discord ya está en su última versión ($INSTALLED_VERSION). No es necesario actualizar."
	rm -f "$DEB_FILE"
	exit 0
fi

echo "📦 Se encontró una nueva versión: $NEW_VERSION (actual: $INSTALLED_VERSION). Procediendo con la actualización..."

# Instalar/actualizar el paquete
sudo dpkg -i "$DEB_FILE"

# Corregir dependencias si es necesario
if [[ $? -ne 0 ]]; then
	echo "⚙️ Reparando dependencias..."
	sudo apt-get install -f -y
fi

# Limpiar archivo temporal
rm -f "$DEB_FILE"

echo "✅ ¡Proceso completado! Discord ha sido actualizado a la versión $NEW_VERSION."
