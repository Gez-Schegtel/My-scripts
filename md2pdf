#!/usr/bin/env zsh

# ==============================================================================
# SCRIPT: md2pdf
# DESCRIPCIÓN: 
#   Convierte archivos Markdown (.md) a formato PDF utilizando Pandoc.
#   Es un script interactivo: si se le pasan archivos por argumento, convierte 
#   solo esos. Si se ejecuta sin argumentos, detecta y procesa todos los 
#   archivos .md del directorio actual. Siempre pide confirmación antes de 
#   iniciar la conversión.
#
# USO:
#   md2pdf                    (Detecta y convierte todos los .md de la carpeta)
#   md2pdf archivo.md         (Convierte solo un archivo específico)
#   md2pdf apunte1.md apunte2.md 
#
# DEPENDENCIAS REQUERIDAS:
#   - zsh (El script está escrito específicamente para Z shell)
#   - pandoc (El conversor universal de documentos)
#   - Motor PDF para Pandoc (LaTeX/TexLive, necesario para exportar a PDF)
#
# Instalación de dependencias en Debian/Ubuntu:
#   sudo apt install zsh pandoc texlive-latex-base texlive-fonts-recommended
# ==============================================================================

set -e
setopt nullglob

# 1. Construimos la lista de archivos a convertir
archivos=()

if (( $# > 0 )); then
  # Si pasaste archivos por argumento: md2pdf a.md b.md
  for archivo in "$@"; do
    [[ -f "$archivo" ]] || continue
    archivos+=("$archivo")
  done
else
  # Si no pasaste nada: todos los .md del directorio
  archivos=(*.md(.N))
fi

# 2. Si no hay archivos, salimos
if (( ${#archivos[@]} == 0 )); then
  echo "No se encontraron archivos Markdown para convertir."
  exit 0
fi

# 3. Mostrar qué se va a convertir
echo "Se van a convertir los siguientes archivos:"
for archivo in "${archivos[@]}"; do
  echo "  - $archivo -> ${archivo%.md}.pdf"
done

# 4. Pedir confirmación
read "respuesta?¿Continuar? [s/N]: "
case "$respuesta" in
  s|S|y|Y)
    echo "Iniciando conversión..."
    ;;
  *)
    echo "Operación cancelada."
    exit 1
    ;;
esac

# 5. Ejecutar pandoc y mostrar mensajes por archivo
for archivo in "${archivos[@]}"; do
  pandoc "$archivo" -o "${archivo%.md}.pdf"
  echo "✔ Generado: ${archivo%.md}.pdf"
done

echo "✅ Conversión completa."
